{
  "name": "vibe-with-dashboard",
  "version": "0.1.0",
  "private": false,
  "description": "Local monitoring dashboard and installable skill for LLM agent project work.",
  "license": "MIT",
  "homepage": "https://github.com/EmeraldTablet42/vibe-with-dashboard",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EmeraldTablet42/vibe-with-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/EmeraldTablet42/vibe-with-dashboard/issues"
  },
  "bin": {
    "vibe-with-dashboard": "./bin/vibe-with-dashboard.js",
    "vibe-dashboard": "./bin/vibe-with-dashboard.js"
  },
  "scripts": {
    "dashboard:ensure": "node bin/vibe-with-dashboard.js ensure",
    "dashboard:activity": "node bin/vibe-with-dashboard.js activity",
    "dashboard:plan": "node bin/vibe-with-dashboard.js plan",
    "dashboard:archive": "node bin/vibe-with-dashboard.js archive",
    "dashboard": "tsx scripts/launcher.ts",
    "dev": "next dev --turbopack --hostname 127.0.0.1 --port 3000",
    "dev:next": "next dev --turbopack --hostname 127.0.0.1 --port 3000",
    "start:e2e": "node scripts/start-e2e.cjs",
    "db:seed": "tsx scripts/seed.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "verify": "npm run lint && npm run typecheck && npm test"
  },
  "files": [
    "bin/",
    "templates/",
    "skills/",
    "src/",
    "scripts/",
    "public/",
    "e2e/",
    "components.json",
    "drizzle.config.ts",
    "eslint.config.mjs",
    "next.config.ts",
    "package-lock.json",
    "playwright.config.ts",
    "postcss.config.mjs",
    "tsconfig.json",
    "vitest.config.ts",
    "README.md",
    "INSTALL.md",
    "CONTEXT.md",
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    "vibe_with_dashboard.md",
    "install.sh",
    "install.ps1",
    "skills-lock.json",
    "LICENSE"
  ],
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.8.2",
    "tailwindcss": "^4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  }
}
